# Copy to .env or export these variables before running real OpenVLA/LIBERO rollouts.
OPENVLA_MODEL_ROOT=/path/to/openvla/models
OPENVLA_BASE_MODEL_DIR=/path/to/openvla-7b
OPENVLA_SPATIAL_MODEL_PATH=/path/to/openvla-7b-finetuned-libero-spatial
LIBERO_DATA_ROOT=/path/to/libero/datasets
OPENVLA_OUTPUT_ROOT=outputs/repro_black_bowl
