# Copy to .env or export these variables before running real OpenVLA/LIBERO rollouts.
#
# The runner (v4_run_eval_openvla.py) reads these from os.environ. The public
# pipeline (run_attack_pipeline.py) does NOT auto-source .env; either source it
# manually or export the variables in your shell profile.
#
# Path conventions below use /data/aviary as an example root. Adjust to your
# local filesystem.

# Root directory containing fine-tuned OpenVLA checkpoints
OPENVLA_MODEL_ROOT=/data/aviary/models/openvla

# Base OpenVLA-7B checkpoint (must contain modeling_prismatic.py etc.)
OPENVLA_BASE_MODEL_DIR=/data/aviary/models/openvla/openvla-7b

# Fine-tuned checkpoint used for the black-bowl task
OPENVLA_SPATIAL_MODEL_PATH=/data/aviary/models/openvla/openvla-7b-finetuned-libero-spatial

# Root of the LIBERO dataset tree (contains datasets/libero_spatial/...)
LIBERO_DATA_ROOT=/data/aviary/datasets/libero

# Where output artifacts (step records, summaries, manifests) are written
OPENVLA_OUTPUT_ROOT=outputs/repro_black_bowl

# ---- Optional GPU tuning ----
# OPENVLA_CUDA_MAX_MEMORY=10000MiB   # per-GPU memory cap for device_map=auto
# CUDA_VISIBLE_DEVICES=0             # restrict which GPUs are visible
# MUJOCO_GL=egl                      # required for headless LIBERO rendering
